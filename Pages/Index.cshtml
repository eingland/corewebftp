@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<h1>Login</h1>
<div class="alert alert-info">@Model.result</div>
<form class="form form-horizontal" method="post">
    <div class="form-group">
        <div class="row">
            <label asp-for="FtpCredential.Uri">Server Address:</label>
            <input asp-for="FtpCredential.Uri" class="form-control">
        </div>
        <div class="row">
            <label asp-for="FtpCredential.Username">Username:</label>
            <input asp-for="FtpCredential.Username" class="form-control">
        </div>
        <div class="row">
            <label asp-for="FtpCredential.Password">Password:</label>
            @Html.PasswordFor(m => m.FtpCredential.Password, new { @class="form-control" })
        </div>
    </div>
    <div class="row">
        <button type="submit" class="btn-primary">Submit</button>
    </div>
</form>